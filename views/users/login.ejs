<% layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <h3 class="col-8 offset-4">Login on WanderLust <i class="fa-regular fa-compass"></i> </h3>
    <div class="col-6 offset-3"> 
        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" name="username" id="username" placeholder="write a username" class="form-control" required/> 
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" name="password" id="password" placeholder="enter a password" class="form-control" required/> 
            </div>

            <button class="btn btn-outline-danger">Login</button>
        </form>
    </div>
</div>